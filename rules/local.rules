# =====================================================================
#  local.rules  –  Snort-style IDS rules (reference / WSL mode)
# =====================================================================

# Network Scanning / Reconnaissance
alert icmp any any -> $HOME_NET any (msg:"ICMP Sweep Detected"; threshold:type both, track by_src, count 10, seconds 5; sid:1000020; rev:1;)
alert tcp any any -> $HOME_NET any (flags:S; msg:"TCP SYN Port Scan Detected"; threshold:type both, track by_src, count 20, seconds 5; sid:1000021; rev:1;)

# SSH Brute Force
alert tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force Attempt"; threshold:type both, track by_src, count 5, seconds 60; sid:1000001; rev:1;)

# FTP Scan
alert tcp any any -> $HOME_NET 21 (msg:"FTP Port Scan"; flags:S; sid:1000002; rev:1;)

# Telnet
alert tcp any any -> $HOME_NET 23 (msg:"Telnet Access Attempt"; sid:1000003; rev:1;)

# Database Exposure
alert tcp any any -> $HOME_NET 3306 (msg:"MySQL Database Port Scanned"; sid:1000004; rev:1;)
alert tcp any any -> $HOME_NET 5432 (msg:"PostgreSQL Port Scanned"; sid:1000005; rev:1;)
alert tcp any any -> $HOME_NET 1433 (msg:"MSSQL Port Scanned"; sid:1000006; rev:1;)
alert tcp any any -> $HOME_NET 6379 (msg:"Redis Port Scanned"; sid:1000012; rev:1;)
alert tcp any any -> $HOME_NET 27017 (msg:"MongoDB Port Scanned"; sid:1000013; rev:1;)

# RDP
alert tcp any any -> $HOME_NET 3389 (msg:"RDP Port Scanned"; sid:1000007; rev:1;)

# SMB
alert tcp any any -> $HOME_NET 445 (msg:"SMB Port Scan – Ransomware Risk"; sid:1000014; rev:1;)
alert tcp any any -> $HOME_NET 139 (msg:"NetBIOS Port Scanned"; sid:1000015; rev:1;)

# HTTP Security
alert http any any -> $HOME_NET any (msg:"Missing Security Headers Detected"; content:"HTTP/1"; sid:2000001; rev:1;)
alert tcp any any -> $HOME_NET 80 (msg:"Unencrypted HTTP Traffic"; sid:2000007; rev:1;)
